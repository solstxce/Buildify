**/GoogleService-Info.plist

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/

# VS Code — uncomment to ignore local launch configs
# .vscode/

# Flutter / Dart / Pub
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
**/build/

# Generated / coverage
coverage/
*.freezed.dart
*.g.dart
# (uncomment if you use code generation heavily)
# *.mocks.dart

# Symbolication / obfuscation
app.*.symbols
app.*.map.json

# Android — see also android/.gitignore
/android/app/debug
/android/app/profile
/android/app/release
**/local.properties

# iOS
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/ServiceDefinitions.json

# macOS (optional local framework copies)
**/macos/Flutter/ephemeral/

# FVM
.fvm/

